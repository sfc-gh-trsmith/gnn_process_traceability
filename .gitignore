# =============================================================================
# GNN Process Traceability - Git Ignore
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Jupyter Notebook
.ipynb_checkpoints/

# Streamlit
streamlit/output/
streamlit/.streamlit/

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# =============================================================================
# NOTE: data/synthetic/ is TRACKED (not ignored)
# 
# The synthetic data files are pre-generated and version-controlled for:
# - Deterministic, reproducible demos
# - No data generation step during deployment
# - Version-controlled data can be reviewed in PRs
# =============================================================================

# Model files (if too large, uncomment)
# *.pkl
# *.joblib
# *.pt
# *.pth

# Snowflake CLI artifacts
.snowflake/

# Environment files with secrets
.env
.env.local
*.secret

# Development scratch files (may contain sensitive local configs)
cursor_scratch/

# Cursor IDE configuration
.cursor/
docs/TEST_PLAN.md
utils
create_user.sh
scratch/
scratch/
solution_presentation/
